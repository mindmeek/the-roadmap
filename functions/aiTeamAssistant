Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        
        // Authenticate user
        const user = await base44.auth.me();
        if (!user) {
            return Response.json({ 
                success: false, 
                error: 'Unauthorized' 
            }, { status: 401 });
        }

        const { 
            assistant_type, 
            user_prompt, 
            context = {}, 
            user_notes = []
        } = await req.json();

        // Validate assistant type
        if (!AI_TEAM[assistant_type]) {
            return Response.json({ 
                success: false, 
                error: 'Invalid assistant type' 
            }, { status: 400 });
        }

        const assistant = AI_TEAM[assistant_type];

        // Build context string
        let contextString = `User's Business Context:
- Stage: ${user.entrepreneurship_stage || 'Not specified'}
- Business Name: ${user.business_name || 'Not specified'}`;

        if (context.section_title) {
            contextString += `\n- Working on: ${context.section_title}`;
        }

        if (user_notes && user_notes.length > 0) {
            contextString += `\n\nUser's Current Notes/Ideas:\n${user_notes.map((note, i) => `${i + 1}. ${note.content}`).join('\n')}`;
        }

        if (context.additional_context) {
            contextString += `\n\nAdditional Context:\n${context.additional_context}`;
        }

        // Build the full prompt
        const fullPrompt = `${assistant.systemPrompt}

${contextString}

User's Question/Request:
${user_prompt}

Provide helpful, specific guidance as ${assistant.name}. Remember to stay in character and focus on your area of expertise. Include relevant platform links to help the user take immediate action.`;

        // Call the LLM - InvokeLLM returns string directly when no JSON schema
        const response = await base44.integrations.Core.InvokeLLM({
            prompt: fullPrompt
        });

        // Check if we got a valid response - response is the string directly
        if (!response || typeof response !== 'string' || response.trim() === '') {
            console.error('Invalid LLM response:', response);
            return Response.json({
                success: false,
                error: 'Failed to get a valid response from AI assistant'
            }, { status: 500 });
        }

        return Response.json({
            success: true,
            response: response,
            assistant: {
                name: assistant.name,
                role: assistant.role,
                avatar: assistant.avatar
            }
        });

    } catch (error) {
        console.error('Error in aiTeamAssistant:', error);
        return Response.json({ 
            success: false, 
            error: error.message || 'An unexpected error occurred'
        }, { status: 500 });
    }
});